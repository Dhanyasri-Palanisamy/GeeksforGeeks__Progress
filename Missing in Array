
class Solution {
    int missingNum(int arr[]) {
        // code here
        long n= arr.length+1;
        long h= ((n*(n+1))/2);
        long sum= 0;
        for(int i=0;i<arr.length;i++){
            sum=sum+arr[i]; //11
        }
       //int  result=(int)h-sum;
        return (int)(h-sum);
        
    }
}

// To find Subarray whose sum is equal to the given targer
class Solution {
    static ArrayList<Integer> subarraySum(int[] arr, int target) {
    
        ArrayList<Integer> list = new ArrayList<Integer>();
  
        int start=0;
        int csum=0;
        for(int i=0;i<arr.length;i++){
             csum += arr[i];
            while(csum>target && start<i){
                csum-=arr[start];
                start++;
            }
            if(target==csum){
                list.add(start+1);
                list.add(i+1);
                return list;
            }
            
            
    }
              
              
              list.add(-1);
      return list;
        }
       
    }

